{
  "expo": {
    "name": "SAVIRA",
    "slug": "savira-mobile",
    "scheme": "savira",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon-savira.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "platforms": [
      "android"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-savira.png",
        "backgroundColor": "#037F81"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.axion.savira"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withDeviceFilePicker"
    ],
    "extra": {
      "router": {},
      "apiUrl": "https://www.saviraphilippines.org",
      "eas": {
        "projectId": "ac9c2835-a599-4eef-ae82-7ddb9defc235"
      }
    }
  }
}
